{%- comment -%}
  Two-column layout. `image_nodes` and `text_nodes` are precomputed in
  render-template.ts — if both are non-empty, render side by side;
  otherwise fall back to a single column of all nodes.

  The tree partial `_render_node` handles all inner content rendering.
{%- endcomment -%}
<div id="content" class="container mx-auto w-full min-h-screen px-8 py-8 flex items-center justify-center" style="background-color: {{ background_color | escape }};">
    <section data-section-type="{{ section_type | escape }}" data-section-id="{{ section_id | escape }}">
        <div class="flex flex-col lg:flex-row px-8 items-start gap-8 max-w-none w-full">
            {%- if image_nodes.size > 0 and text_nodes.size > 0 -%}
                <div class="basis-full lg:basis-1/2 p-4 flex flex-col items-center" style="color: {{ text_color | escape }};">
                    {% include "_render_node", nodes: text_nodes, depth: 0 %}
                </div>
                <div class="basis-full lg:basis-1/2 p-4 flex flex-col items-center lg:justify-center lg:min-h-screen" style="color: {{ text_color | escape }};">
                    {% include "_render_node", nodes: image_nodes, depth: 0 %}
                </div>
            {%- else -%}
                <div class="basis-full p-4 flex flex-col items-center" style="color: {{ text_color | escape }};">
                    {% include "_render_node", nodes: nodes, depth: 0 %}
                </div>
            {%- endif -%}
        </div>
    </section>
</div>
