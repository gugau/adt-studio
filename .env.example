# Port to expose the ADT Studio web interface (default: 8080)
PORT=8080

# Optional external evaluation service used by Translation Evaluation.
# Leave blank to disable evaluation runs from the Studio UI.
EVAL_SERVICE_URL=
EVAL_SERVICE_TOKEN=

# Optional credentials typically needed by the external eval service itself.
# These are included here as deployment placeholders for compose-based setups.
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_TRACKING_TOKEN=
MLFLOW_EXPERIMENT_NAME=adt-translation-evaluation
MLFLOW_PORT=5001
OPENAI_API_KEY=
