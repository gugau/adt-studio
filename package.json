{
  "name": "adt-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "predev": "pnpm build",
    "pretest": "pnpm build",
    "test": "vitest run",
    "test:watch": "pnpm build && vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --build",
    "lint": "eslint",
    "clean": "tsc --build --clean",
    "build": "pnpm tsc --build && pnpm --filter @adt/runtime build",
    "dev": "node scripts/dev.mjs",
    "dev:api": "pnpm --filter @adt/api dev",
    "dev:studio": "pnpm --filter @adt/studio dev",
    "dev:desktop": "pnpm --parallel --filter @adt/desktop --filter @adt/studio dev --mode desktop",
    "build:desktop": "pnpm build && pnpm --filter @adt/desktop build",
    "pdf-extract": "tsx packages/pdf/src/cli.ts",
    "pipeline": "tsx packages/pipeline/src/cli.ts",
    "a11y:regression": "tsx scripts/run-curated-a11y-regression.ts --build",
    "a11y:regression:json": "tsx scripts/run-curated-a11y-regression.ts --build --format json",
    "a11y:browser-recheck": "tsx scripts/run-browser-a11y-recheck.ts --build",
    "a11y:browser-recheck:json": "tsx scripts/run-browser-a11y-recheck.ts --build --format json",
    "postinstall": "node -e \"!process.env.CI && process.env.NODE_ENV !== 'production' && require('fs').writeFileSync('CLAUDE.md', '@AGENTS.md\\n')\""
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@vitest/coverage-v8": "4.0.18",
    "axe-core": "^4.11.1",
    "docx": "^9.7.1",
    "jsdom": "^27.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18",
    "xlsx": "^0.18.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "electron"
    ]
  },
  "license": "AGPL-3.0-or-later"
}
